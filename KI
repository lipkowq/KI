import matplotlib.pyplot as plt
import random as rnd
valuesRange = [1, 99, 0, 30, 7, 39, 1, 99]

# turn application into string
def apply(RValue, YoEValue, GPAValue, CRValue):
 race = str("R" + str(RValue).zfill(2) + " ")
 yearsofexperience = str("YoE" + str(YoEValue).zfill(2) + " ")
 gpa = str("GPA" + str(GPAValue).zfill(2) + " ")
 collegeranking = str("CR" + str(CRValue).zfill(2))
 return str(race + yearsofexperience + gpa + collegeranking)


# make n applications
applications = []
applicants = int(input("How many applicants?\n"))
for _ in range(applicants):
 applications.append(apply(rnd.randint(valuesRange[0], valuesRange[1]), \
rnd.randint(valuesRange[2], valuesRange[3]), \
rnd.randint(valuesRange[4], valuesRange[5]), \
rnd.randint(valuesRange[6], valuesRange[7])))

baseData = {"application1": "Error!"}


def grade(data, raceWeight, YoEWeight, GPAWeight, CRWeight):
 for idx in range(applicants):
   score = (int((applications[idx])[1:2]) * raceWeight) + \
   (int((applications[idx])[7:8]) * YoEWeight) + \
   (int((applications[idx])[13:14]) * GPAWeight) + \
   (int((applications[idx])[-1:]) * CRWeight)
   data[str("application" + str(idx + 1))] = round(score, 1)


# data for the ai to reach
grade(baseData, 0, 5, -4, -0.5)


# calculate avg difference
def setDifference(data1, data2):
 if len(data1) != len(data2):
   return (100)
 else:
   difference = 0
   for idx in range(len(data1)):
     difference += abs(data1["application" + str(idx + 1)] - \
     data2["application" + str(idx + 1)])
   return difference / len(data1)


# variables
weightAI = [0.0, 0, 0, 0]
dataAI = {"application1": "placeholder"}
differenceHistory = [setDifference(baseData, dataAI)]
raceHistory = [0]
yearsofEHistory = [0]
gpaHistory = [0]
collegeRHistory = [0]

def gradeAI():
 return grade(dataAI, \
              weightAI[0], \
              weightAI[1], \
              weightAI[2], \
              weightAI[3])

# actually update ai until it's done or on a minima
weightHistory = [[0.0, 0, 0, 0, 0]]
while differenceHistory[-1] > 0 and len(differenceHistory) < 500:
 gradeAI()
 selectedChange = rnd.randint(0, 3)
 beforeDifference = differenceHistory[-1]
 weightAI[selectedChange] = round(weightAI[selectedChange] + 0.1, 1)
 gradeAI()
 afterDifference = setDifference(baseData, dataAI)
 if beforeDifference <= afterDifference:
   weightAI[selectedChange] = round(weightAI[selectedChange] - 0.2, 1)
   gradeAI()
   afterDifference = setDifference(baseData, dataAI)
   if beforeDifference <= afterDifference:
     weightAI[selectedChange] = round(weightAI[selectedChange] + 0.1, 1)
     gradeAI()
     afterDifference = setDifference(baseData, dataAI)
 print(round(afterDifference, 3))
 differenceHistory.append(afterDifference)
 raceHistory.append(weightAI[0])
 yearsofEHistory.append(weightAI[1])
 gpaHistory.append(weightAI[2])
 collegeRHistory.append(weightAI[3])

print(str(weightAI))

#display
if input("Score or weights? ") == "score":
 plt.plot(differenceHistory[1:])
else:
 plt.plot(raceHistory)
 plt.plot(yearsofEHistory)
 plt.plot(gpaHistory)
 plt.plot(collegeRHistory)
plt.show()
